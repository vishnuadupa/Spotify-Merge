# Python
__pycache__/
*.pyc

# Virtual environments
venv/
env/
.env

# Secrets & Caches
config.json
.cache-old*
.cache-new*
.migration_state.json

# Databases
*.db
*.db-shm
*.db-wal

# Editor / OS
.vscode/
.idea/
.DS_Store

# Agents
.agents/
.claude/
skills-lock.json

# User Data
*.json
